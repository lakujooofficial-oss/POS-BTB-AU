<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F7F7F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="POS BTB AU"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/buttonProducts"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Products"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/buttonCart"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Cart"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/buttonReports"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Reports"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/buttonPrinter"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Printer"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionProducts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product Catalogue"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/buttonAddProduct"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Tambah Produk"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/buttonAddPromotion"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Tambah Promo"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tekan produk untuk menambah ke keranjang. Tekan lama untuk hapus produk dari katalog." 
                android:textSize="14sp"
                android:textColor="#4B5563"
                android:layout_marginBottom="8dp" />

            <ListView
                android:id="@+id/productListView"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:dividerHeight="1dp"
                android:layout_marginBottom="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionCart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:visibility="gone"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cart"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Promo:"
                    android:textColor="#374151"
                    android:gravity="center_vertical" />

                <Spinner
                    android:id="@+id/promotionSpinner"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <ListView
                android:id="@+id/cartListView"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:dividerHeight="1dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textCartTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total: Rp 0.00"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/buttonCheckout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Checkout" />

            <Button
                android:id="@+id/buttonClearCart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kosongkan Keranjang"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionReports"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:visibility="gone"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Laporan"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/buttonViewTodaySales"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Hari Ini"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/buttonViewWeeklySales"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Minggu"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/textReportSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tidak ada data penjualan saat ini."
                android:textColor="#4B5563"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/buttonPrintReport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cetak Laporan Harian" />

            <Button
                android:id="@+id/buttonPrintWeeklyReport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cetak Laporan Mingguan"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/buttonSyncSupabase"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sinkronisasi ke Supabase"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionPrinter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:visibility="gone"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Printer"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/buttonRefreshPrinters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Refresh Paired Printers" />

            <Spinner
                android:id="@+id/printerSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/buttonConnectPrinter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Connect Printer"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/textPrinterStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Printer tidak terhubung"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/buttonPrintLastReceipt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cetak Resi Terakhir"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
